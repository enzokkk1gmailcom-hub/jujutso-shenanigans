local function refreshTeams()
    for _, child in ipairs(teamsScroll:GetChildren()) do if child:IsA("Frame") then child:Destroy() end end
    local tms = teamsService:GetTeams()
    local y = 0
    if #tms == 0 then
        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(1, -10, 0, 30)
        lbl.BackgroundTransparency = 1
        lbl.Text = "No teams available."
        lbl.TextColor3 = Color3.fromRGB(255, 255, 255)
        lbl.Font = Enum.Font.SourceSans
        lbl.TextSize = 13
        lbl.Parent = teamsScroll
        y = 35
    else
        for _, team in ipairs(tms) do
            if not team:IsA("Team") then continue end
            local frame = Instance.new("Frame")
            frame.Size = UDim2.new(1, -10, 0, 28)
            frame.Position = UDim2.new(0, 5, 0, y)
            frame.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
            frame.Parent = teamsScroll

            local label = Instance.new("TextLabel")
            label.Size = UDim2.new(0.6, 0, 1, 0)
            label.BackgroundTransparency = 1
            label.Text = team.Name
            label.TextColor3 = Color3.fromRGB(255, 255, 255)
            label.Font = Enum.Font.SourceSans
            label.TextSize = 12
            label.Parent = frame

            local joinBtn = Instance.new("TextButton")
            joinBtn.Size = UDim2.new(0.4, -10, 1, 0)
            joinBtn.Position = UDim2.new(0.6, 5, 0, 0)
            joinBtn.BackgroundColor3 = themes[currentTheme].accent
            joinBtn.Text = "Join"
            joinBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
            joinBtn.Font = Enum.Font.SourceSansBold
            joinBtn.TextSize = 12
            joinBtn.Parent = frame
            joinBtn.MouseButton1Click:Connect(function()
                pcall(function() player.Team = team end)
                local replicated = replicatedStorage
                for _, remoteName in ipairs({"SetTeam", "JoinTeam", "ChangeTeam", "TeamSelect"}) do
                    local event = replicated:FindFirstChild(remoteName)
                    if event and event:IsA("RemoteEvent") then
                        pcall(function() event:FireServer(team) end)
                        pcall(function() event:FireServer(player, team) end)
                    end
                end
                joinBtn.Text = "OK!"
                task.wait(0.5)
                joinBtn.Text = "Join"
            end)

            y += 30
        end
    end
    teamsScroll.CanvasSize = UDim2.new(0, 0, 0, y)
end
teamsBtn.MouseButton1Click:Connect(refreshTeams)

