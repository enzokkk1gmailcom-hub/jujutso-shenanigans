local function fetchWeapons()
    local tools = {}
    local ss = serverStorage
    for _, obj in ipairs(ss:GetDescendants()) do if obj:IsA("Tool") then tools[obj.Name] = obj end end
    if next(tools) == nil then
        local rs = replicatedStorage
        for _, obj in ipairs(rs:GetDescendants()) do if obj:IsA("Tool") then tools[obj.Name] = obj end end
    end
    return tools
end

