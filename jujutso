-- Função para criar tracers
local function createTracer(from, to, color)
    local part = Instance.new("Part")
    part.Size = Vector3.new(0.1, 0.1, (from - to).Magnitude)
    part.CFrame = CFrame.new(from, to) * CFrame.new(0, 0, -part.Size.Z / 2)
    part.Anchored = true
    part.CanCollide = false
    part.Color = color
    part.Material = Enum.Material.Neon
    part.Parent = ws
    table.insert(tracerParts, part)
    return part
end

-- Loop ESP
runService.Heartbeat:Connect(function()
    for _, part in ipairs(tracerParts) do if part then part:Destroy() end end
    tracerParts = {}

    if streamMode then
        for _, plr in ipairs(game:GetService("Players"):GetPlayers()) do
            if plr.Character then
                for _, obj in ipairs(plr.Character:GetDescendants()) do
                    if obj:IsA("Highlight") and obj.Name == "ESP_HL" then obj:Destroy() end
                    if obj:IsA("SelectionBox") and obj.Name == "ESP_B" then obj:Destroy() end
                    if obj:IsA("BillboardGui") then
                        local n = obj.Name
                        if n == "ESP_N" or n == "ESP_D" or n == "ESP_W" or n == "ESP_HP" then obj:Destroy() end
                    end
                end
            end
        end
        return
    end

    for _, plr in ipairs(game:GetService("Players"):GetPlayers()) do
        if plr ~= player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local char = plr.Character
            local root = char.HumanoidRootPart
            local humanoid = char:FindFirstChild("Humanoid")
            local head = char:FindFirstChild("Head") or char:FindFirstChild("UpperTorso")

            if espSettings.skeleton then
                local hl = char:FindFirstChild("ESP_HL") or Instance.new("Highlight", char)
                hl.Name = "ESP_HL"; hl.FillTransparency = 1; hl.OutlineColor = Color3.new(1,0,0); hl.OutlineTransparency = 0
            elseif char:FindFirstChild("ESP_HL") then char.ESP_HL:Destroy() end

            if head then
                if espSettings.name then
                    local bg = head:FindFirstChild("ESP_N") or Instance.new("BillboardGui", head)
                    bg.Name = "ESP_N"; bg.Size = UDim2.new(0,100,0,20); bg.StudsOffset = Vector3.new(0,2.5,0); bg.AlwaysOnTop = true
                    local txt = Instance.new("TextLabel", bg); txt.Text = plr.Name; txt.TextColor3=Color3.new(1,1,1); txt.BackgroundTransparency=1; txt.Font=Enum.Font.SourceSans; txt.TextSize=12
                elseif head:FindFirstChild("ESP_N") then head.ESP_N:Destroy() end

                if espSettings.distance then
                    local dist = player.Character and player.Character:FindFirstChild("HumanoidRootPart") and math.floor((player.Character.HumanoidRootPart.Position - root.Position).Magnitude) or 0
                    local bg = head:FindFirstChild("ESP_D") or Instance.new("BillboardGui", head)
                    bg.Name = "ESP_D"; bg.Size = UDim2.new(0,80,0,18); bg.StudsOffset = Vector3.new(0,-2.5,0); bg.AlwaysOnTop = true
                    local txt = bg:FindFirstChild("TextLabel") or Instance.new("TextLabel", bg)
                    txt.Text = dist.."m"; txt.TextColor3=Color3.new(1,1,1); txt.BackgroundTransparency=1; txt.Font=Enum.Font.SourceSans; txt.TextSize=11
                elseif head:FindFirstChild("ESP_D") then head.ESP_D:Destroy() end

                if espSettings.weapon then
                    local tool = plr.Character:FindFirstChildOfClass("Tool")
                    if tool then
                        local bg = head:FindFirstChild("ESP_W") or Instance.new("BillboardGui", head)
                        bg.Name = "ESP_W"; bg.Size = UDim2.new(0,120,0,18); bg.StudsOffset = Vector3.new(0,1.5,0); bg.AlwaysOnTop = true
                        local txt = bg:FindFirstChild("TextLabel") or Instance.new("TextLabel", bg)
                        txt.Text = "["..tool.Name.."]"; txt.TextColor3=Color3.new(1,1,1); txt.BackgroundTransparency=1; txt.Font=Enum.Font.SourceSans; txt.TextSize=10
                    elseif head:FindFirstChild("ESP_W") then head.ESP_W:Destroy() end
                elseif head:FindFirstChild("ESP_W") then head.ESP_W:Destroy() end

                if espSettings.health and humanoid then
                    local percent = humanoid.Health / humanoid.MaxHealth
                    local bar = head:FindFirstChild("ESP_HP") or Instance.new("BillboardGui", head)
                    bar.Name = "ESP_HP"; bar.Size = UDim2.new(0,40,0,6); bar.StudsOffset = Vector3.new(0,-3.2,0); bar.AlwaysOnTop = true
                    local fill = bar:FindFirstChild("Fill") or Instance.new("Frame", bar)
                    fill.Size = UDim2.new(percent,0,1,0); fill.BackgroundColor3 = Color3.fromRGB(255,0,0); fill.BorderSizePixel=0; fill.Name="Fill"
                elseif head:FindFirstChild("ESP_HP") then head.ESP_HP:Destroy() end
            end

            if espSettings.box then
                local sb = char:FindFirstChild("ESP_B") or Instance.new("SelectionBox", char)
                sb.Name = "ESP_B"; sb.Adornee = char; sb.Color3 = Color3.new(0,1,0)
            elseif char:FindFirstChild("ESP_B") then char.ESP_B:Destroy() end

            if espSettings.line then
                createTracer(cam.CFrame.Position, root.Position, Color3.fromRGB(255,0,0))
            end
        end
    end
end)

