    currentTheme = themeName
    mainFrame.BorderColor3 = t.border
    titleBar.BorderColor3 = t.border
    sidebar.BorderColor3 = t.border
    contentArea.BorderColor3 = t.border
    titleText.TextColor3 = t.textAccent
