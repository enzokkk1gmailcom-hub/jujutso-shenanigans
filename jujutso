            local isOn = child.Text == "ON"
            child.BackgroundColor3 = isOn and t.accent or Color3.fromRGB(70, 0, 0)
        end
        if child:IsA("Frame") and child.Name == "Fill" then
            child.BackgroundColor3 = t.border
