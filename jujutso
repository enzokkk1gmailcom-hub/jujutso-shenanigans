-- ================== AIMBOT ==================
local aimOn = false
local aimSmooth = 0.3

toggle(aimTab, 5, "Aimbot", function(on) aimOn = on end)
slider(aimTab, 35, "Suavidade", 0.1, 1, 0.3, function(v) aimSmooth = v end)

runService.Heartbeat:Connect(function()
    if not aimOn or not player.Character then return end
    local target = nil
    local minDist = math.huge
    for _, plr in ipairs(game:GetService("Players"):GetPlayers()) do
        if plr ~= player and plr.Character and plr.Character:FindFirstChild("Head") then
            local dist = (cam.CFrame.Position - plr.Character.Head.Position).Magnitude
            if dist < minDist then
                minDist = dist
                target = plr.Character.Head
            end
        end
    end
    if target then
        cam.CFrame = cam.CFrame:Lerp(CFrame.new(cam.CFrame.Position, target.Position), aimSmooth)
    end
end)

