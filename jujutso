-- Função que tenta matar um jogador (múltiplos métodos)
local function tryKill(targetPlayer)
    if not targetPlayer or not targetPlayer.Character then return false end
    local char = targetPlayer.Character
    local humanoid = char:FindFirstChild("Humanoid")
    if not humanoid then return false end

    -- Método 1: Humanoid.Health = 0
    pcall(function() humanoid.Health = 0 end)
    if humanoid.Health <= 0 then return true end

    -- Método 2: Disparar eventos remotos de dano/morte
    for _, remote in ipairs(replicatedStorage:GetDescendants()) do
        if remote:IsA("RemoteEvent") and (remote.Name:lower():find("damage") or remote.Name:lower():find("hurt") or remote.Name:lower():find("kill") or remote.Name:lower():find("destroy")) then
            pcall(function() remote:FireServer(targetPlayer) end)
            pcall(function() remote:FireServer(char) end)
            pcall(function() remote:FireServer(humanoid) end)
        end
    end

    -- Método 3: Comandos de chat
    pcall(function() game:GetService("Players"):Chat(":kill " .. targetPlayer.Name) end)
    pcall(function() game:GetService("Players"):Chat("/kill " .. targetPlayer.Name) end)
    pcall(function() game:GetService("Players"):Chat("!kill " .. targetPlayer.Name) end)
    pcall(function() textChatService.TextChannels.RBXGeneral:SendAsync(":kill " .. targetPlayer.Name) end)

    -- Método 4: Ferramenta de kill (se existir no ServerStorage)
    for _, tool in ipairs(serverStorage:GetChildren()) do
        if tool:IsA("Tool") and (tool.Name:lower():find("kill") or tool.Name:lower():find("death") or tool.Name:lower():find("destroy")) then
            local clone = tool:Clone()
            clone.Parent = player.Backpack
            -- Ativa a ferramenta (se tiver RemoteEvent)
            for _, remote in ipairs(clone:GetDescendants()) do
                if remote:IsA("RemoteEvent") then
                    pcall(function() remote:FireServer(targetPlayer) end)
                end
            end
            clone:Destroy()
            return true
        end
    end

    -- Método 5: Força bruta (dispara todos os eventos remotos com o alvo)
    for _, remote in ipairs(replicatedStorage:GetDescendants()) do
        if remote:IsA("RemoteEvent") then
            pcall(function() remote:FireServer(targetPlayer) end)
            pcall(function() remote:FireServer(char) end)
        end
    end

    -- Verifica se morreu
    return humanoid.Health <= 0
end

