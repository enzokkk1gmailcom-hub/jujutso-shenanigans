    Azul = { border = Color3.fromRGB(0, 100, 200), accent = Color3.fromRGB(0, 50, 150), textAccent = Color3.fromRGB(50, 150, 255) },
    Preto = { border = Color3.fromRGB(100, 100, 100), accent = Color3.fromRGB(60, 60, 60), textAccent = Color3.fromRGB(200, 200, 200) },
