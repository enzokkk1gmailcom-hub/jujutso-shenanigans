runService.Heartbeat:Connect(function()
    if streamMode then clearFOVCircle(); return end
    if aimActive then
        aimFOVCircle.Visible = true
        aimFOVCircle.Position = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)
        aimFOVCircle.Radius = aimFOV
    else aimFOVCircle.Visible = false end
    if not aimActive then return end
    local char = player.Character; if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local target = nil; local minAngle = aimFOV
    for _, plr in ipairs(game:GetService("Players"):GetPlayers()) do
        if plr ~= player and plr.Character and plr.Character:FindFirstChild(aimPart) then
            local part = plr.Character[aimPart]
            local dir = (part.Position - cam.CFrame.Position).Unit
            local angle = math.acos(cam.CFrame.LookVector:Dot(dir)) * 180 / math.pi
            if angle < minAngle then minAngle = angle; target = part end
        end
    end
    if target then cam.CFrame = cam.CFrame:Lerp(CFrame.new(cam.CFrame.Position, target.Position), aimSmooth) end
end)

