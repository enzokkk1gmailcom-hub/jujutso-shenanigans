local function toggle(parent, y, text, callback)
    local f = Instance.new("Frame", parent)
    f.Size = UDim2.new(1, -10, 0, 24)
    f.Position = UDim2.new(0, 5, 0, y)
    f.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    
    local lbl = Instance.new("TextLabel", f)
    lbl.Text = text
    lbl.Size = UDim2.new(0.6, 0, 1, 0)
    lbl.BackgroundTransparency = 1
    lbl.TextColor3 = Color3.fromRGB(255, 255, 255)
    lbl.Font = Enum.Font.SourceSans
    lbl.TextSize = 11
    
    local btn = Instance.new("TextButton", f)
    btn.Size = UDim2.new(0.4, -4, 0, 18)
    btn.Position = UDim2.new(0.6, 2, 0, 3)
    btn.BackgroundColor3 = Color3.fromRGB(70, 0, 0)
    btn.Text = "OFF"
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.SourceSansBold
    btn.TextSize = 10
    
    local on = false
    btn.MouseButton1Click:Connect(function()
        on = not on
        btn.Text = on and "ON" or "OFF"
        btn.BackgroundColor3 = on and Color3.fromRGB(150, 0, 0) or Color3.fromRGB(70, 0, 0)
        callback(on)
    end)
end

local function slider(parent, y, text, min, max, val, callback)
    local lbl = Instance.new("TextLabel", parent)
    lbl.Size = UDim2.new(1, -10, 0, 14)
    lbl.Position = UDim2.new(0, 5, 0, y)
    lbl.BackgroundTransparency = 1
    lbl.Text = text .. ": " .. val
    lbl.TextColor3 = Color3.fromRGB(255, 255, 255)
    lbl.Font = Enum.Font.SourceSans
    lbl.TextSize = 10
    
    local track = Instance.new("Frame", parent)
    track.Size = UDim2.new(1, -20, 0, 5)
    track.Position = UDim2.new(0, 10, 0, y + 16)
    track.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    
    local fill = Instance.new("Frame", track)
    fill.Size = UDim2.new((val - min) / (max - min), 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
    
    local handle = Instance.new("TextButton", track)
    handle.Size = UDim2.new(0, 12, 0, 12)
    handle.Position = UDim2.new((val - min) / (max - min), -6, 0.5, -6)
    handle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    handle.Text = ""
    
    local function update(posX)
        local p = math.clamp((posX - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        local v = math.floor(min + p * (max - min))
        fill.Size = UDim2.new(p, 0, 1, 0)
        handle.Position = UDim2.new(p, -6, 0.5, -6)
        lbl.Text = text .. ": " .. v
        callback(v)
    end
    
    handle.MouseButton1Down:Connect(function()
        local conn
        conn = uis.InputChanged:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
                update(input.Position.X)
            end
        end)
        uis.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                conn:Disconnect()
            end
        end)
    end)
end

-- ================== MAIN ==================
local flyOn = false
local flySpeed = 100
local bv, bg

toggle(mainTab, 5, "Fly", function(on)
    flyOn = on
    if on and player.Character then
        local root = player.Character:FindFirstChild("HumanoidRootPart")
        if root then
            if bv then bv:Destroy() end
            if bg then bg:Destroy() end
            bv = Instance.new("BodyVelocity", root)
            bv.MaxForce = Vector3.new(flySpeed * 1000, flySpeed * 1000, flySpeed * 1000)
            bv.P = 10000
            bg = Instance.new("BodyGyro", root)
            bg.MaxTorque = Vector3.new(400000, 400000, 400000)
            bg.P = 10000
            
            runService.Heartbeat:Connect(function()
                if not flyOn or not root or not root.Parent then return end
                local cf = cam.CFrame
                local move = Vector3.zero
                if uis:IsKeyDown(Enum.KeyCode.W) then move += cf.LookVector end
                if uis:IsKeyDown(Enum.KeyCode.S) then move -= cf.LookVector end
                if uis:IsKeyDown(Enum.KeyCode.A) then move -= cf.RightVector end
                if uis:IsKeyDown(Enum.KeyCode.D) then move += cf.RightVector end
                if uis:IsKeyDown(Enum.KeyCode.Space) then move += Vector3.new(0, 1, 0) end
                if bv then bv.Velocity = move.Magnitude > 0 and move.Unit * flySpeed or Vector3.zero end
                if bg then bg.CFrame = cf end
            end)
        end
    end
end)

slider(mainTab, 35, "Velocidade", 50, 500, 100, function(v)
    flySpeed = v
    if bv then bv.MaxForce = Vector3.new(v * 1000, v * 1000, v * 1000) end
end)

